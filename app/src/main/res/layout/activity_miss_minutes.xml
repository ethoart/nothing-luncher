<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/missRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- GIF fills FULL SCREEN -->
    <ImageView
        android:id="@+id/missGifView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Miss Minutes" />

    <!-- Dark gradient overlay at bottom so text is readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_gradient" />

    <!-- Conversation: Miss Minutes reply (amber bubble above) -->
    <TextView
        android:id="@+id/missReplyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="38dp"
        android:background="@drawable/bg_speech_bubble"
        android:textColor="#1A0800"
        android:textSize="9sp"
        android:padding="8dp"
        android:gravity="center"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone"
        android:text="" />

    <!-- User speech echo (small, above Miss reply) -->
    <TextView
        android:id="@+id/userSpeechText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="88dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@drawable/bg_status_chip"
        android:textColor="#FFCC66"
        android:textSize="7sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:visibility="gone"
        android:text="" />

    <!-- Status + mic button at very bottom center -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <!-- Mic pulse indicator -->
        <View
            android:id="@+id/micPulse"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_pill" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF8C00"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:text="TAP TO TALK" />
    </LinearLayout>

    <!-- Time overlay — top center -->
    <TextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="3dp"
        android:text="00:00"
        android:textColor="#FFAA00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:shadowColor="#CC000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:visibility="gone" />

</FrameLayout>
